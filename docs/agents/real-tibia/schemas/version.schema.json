{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "version.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "baselines"],
  "properties": {
    "schema_version": {"const": 1},
    "baselines": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["id", "captured_at", "server", "notes"], "properties": {"id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}, "captured_at": {"type": "string", "format": "date-time"}, "server": {"type": "object", "additionalProperties": false, "required": ["repository", "sha"], "properties": {"repository": {"const": "blakinio/canary"}, "sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"}}}, "protocol": {"type": "integer", "minimum": 1}, "client": {"type": "object"}, "upstream": {"type": "object"}, "donors": {"type": "array", "items": {"type": "object"}}, "notes": {"type": "array", "items": {"type": "string"}}}}}
  }
}
