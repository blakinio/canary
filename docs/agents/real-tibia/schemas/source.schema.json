{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "source.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "sources"],
  "properties": {
    "schema_version": {"const": 1},
    "sources": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["id", "name", "type", "writable", "exact_sha_required", "authority"], "properties": {"id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}, "name": {"type": "string", "minLength": 2}, "type": {"type": "string", "minLength": 2}, "writable": {"type": "boolean"}, "exact_sha_required": {"type": "boolean"}, "authority": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string"}}}}}
  }
}
