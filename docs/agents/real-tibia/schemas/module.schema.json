{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "module.schema.json",
  "title": "Real Tibia module record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "module_id",
    "name",
    "category",
    "description",
    "lifecycle",
    "scope",
    "paths",
    "relationships",
    "documents",
    "source_requirements",
    "maturity",
    "freshness",
    "notes"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "module_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "name": {"type": "string", "minLength": 2},
    "category": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "description": {"type": "string", "minLength": 10},
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "enum": [
            "inventory",
            "mapped",
            "active",
            "paused",
            "historical",
            "deprecated",
            "archived"
          ]
        },
        "program": {"type": "string", "pattern": "^docs/agents/programs/.+\\.md$"}
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["includes", "excludes"],
      "properties": {
        "includes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 2}},
        "excludes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 2}}
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["server", "client", "data", "tests", "docs"],
      "properties": {
        "server": {"$ref": "#/$defs/paths"},
        "client": {"$ref": "#/$defs/paths"},
        "data": {"$ref": "#/$defs/paths"},
        "tests": {"$ref": "#/$defs/paths"},
        "docs": {"$ref": "#/$defs/paths"}
      }
    },
    "relationships": {
      "type": "object",
      "additionalProperties": false,
      "required": ["depends_on", "interacts_with"],
      "properties": {
        "depends_on": {"$ref": "#/$defs/ids"},
        "interacts_with": {"$ref": "#/$defs/ids"}
      }
    },
    "documents": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validation"],
      "properties": {
        "program": {"type": "string"},
        "validation": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "source_requirements": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "mode"],
        "properties": {
          "source": {"type": "string"},
          "mode": {
            "enum": [
              "required",
              "required-when-related",
              "required-when-parity",
              "conditional",
              "secondary",
              "comparison-only"
            ]
          }
        }
      }
    },
    "maturity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "implementation",
        "evidence",
        "persistence",
        "protocol",
        "automated_tests",
        "runtime_validation",
        "gameplay_e2e"
      ],
      "properties": {
        "implementation": {"enum": ["not-assessed", "inventory", "mapped", "partial", "verified", "not-applicable"]},
        "evidence": {"enum": ["not-assessed", "inventory", "mapped", "audited", "verified", "not-applicable"]},
        "persistence": {"$ref": "#/$defs/boundary"},
        "protocol": {"$ref": "#/$defs/boundary"},
        "automated_tests": {"enum": ["not-assessed", "missing", "unit", "integration", "verified", "not-applicable"]},
        "runtime_validation": {"enum": ["not-assessed", "missing", "limited", "verified", "not-applicable"]},
        "gameplay_e2e": {"enum": ["not-assessed", "missing", "partial", "verified", "not-applicable"]}
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class", "last_inventory", "warning_after_days", "invalid_after_days", "refresh_before_each_task"],
      "properties": {
        "class": {"enum": ["fast", "medium", "slow", "immutable"]},
        "last_inventory": {"type": "string", "format": "date"},
        "warning_after_days": {"type": "integer", "minimum": 1},
        "invalid_after_days": {"type": "integer", "minimum": 1},
        "refresh_before_each_task": {"type": "boolean"}
      }
    },
    "notes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
  },
  "$defs": {
    "paths": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "boundary": {"enum": ["not-assessed", "missing", "partial", "verified", "not-applicable"]}
  }
}
