{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "category.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "categories"],
  "properties": {
    "schema_version": {"const": 1},
    "categories": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["id", "name", "description"], "properties": {"id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}, "name": {"type": "string", "minLength": 2}, "description": {"type": "string", "minLength": 10}}}}
  }
}
