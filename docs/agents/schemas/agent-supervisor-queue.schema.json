{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-supervisor-queue.schema.json",
  "title": "Canary agent supervisor queue",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "queue_id", "budget_policy", "max_parallel", "items"],
  "properties": {
    "schema_version": {"const": 1},
    "queue_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "budget_policy": {
      "enum": ["minimize_agentic_usage", "balanced", "capability_first"]
    },
    "max_parallel": {"type": "integer", "minimum": 1, "maximum": 16},
    "completed": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true,
      "default": []
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "task"],
        "properties": {
          "id": {"type": "string", "minLength": 1, "maxLength": 128},
          "task": {"type": "string", "minLength": 1},
          "task_text": {"type": "string", "maxLength": 2000, "default": ""},
          "depends_on": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true,
            "default": []
          },
          "target_mode": {"enum": ["auto", "chat", "codex", "work"], "default": "auto"},
          "needs_local_execution": {"type": "boolean", "default": false},
          "broad_research": {"type": "boolean", "default": false},
          "large_deliverable": {"type": "boolean", "default": false},
          "parallel_workers": {"type": "boolean", "default": false},
          "github_only": {"type": "boolean", "default": false},
          "changed_paths": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true,
            "default": []
          },
          "extra_routes": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true,
            "default": []
          }
        }
      }
    }
  }
}
