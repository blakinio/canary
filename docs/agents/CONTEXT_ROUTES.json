{
  "schema_version": 1,
  "budget_policy": "minimize_agentic_usage",
  "limits": {
    "max_required_reads": 12,
    "max_search_first": 10,
    "max_optional_reads": 8,
    "max_proven": 12,
    "max_unknown": 8,
    "max_conflicts": 6,
    "max_changed_paths": 12,
    "max_validation": 8,
    "max_blockers": 6
  },
  "core_reads": [
    "AGENTS.md",
    "docs/agents/REPOSITORY_MAP.md",
    "docs/agents/CONTEXT_ROUTING.md"
