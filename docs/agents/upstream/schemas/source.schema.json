{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blakinio/canary/docs/agents/upstream/schemas/source.schema.json",
  "title": "Canary upstream intelligence source registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report", "sources"],
  "properties": {
    "schema_version": {"const": 1},
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "issue_title", "max_issue_body_chars", "max_report_rows"],
      "properties": {
        "repository": {"const": "blakinio/canary"},
        "issue_title": {"type": "string", "minLength": 1, "maxLength": 160},
        "max_issue_body_chars": {"type": "integer", "minimum": 1000, "maximum": 65000},
        "max_report_rows": {"type": "integer", "minimum": 1, "maximum": 500}
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id", "name", "repository", "role", "writable", "default_branch",
          "kinds", "max_items_per_kind", "max_pages", "daily_file_details",
          "deep_file_details", "initial_baseline"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
          "name": {"type": "string", "minLength": 1},
          "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
          "role": {"enum": ["upstream-server", "upstream-client", "donor-server", "editor"]},
          "writable": {"const": false},
          "default_branch": {"type": "string", "minLength": 1},
          "kinds": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"enum": ["commits", "pulls", "issues", "releases"]}
          },
          "max_items_per_kind": {"type": "integer", "minimum": 1, "maximum": 500},
          "max_pages": {"type": "integer", "minimum": 1, "maximum": 10},
          "daily_file_details": {"type": "integer", "minimum": 0, "maximum": 500},
          "deep_file_details": {"type": "integer", "minimum": 0, "maximum": 500},
          "initial_baseline": {
            "type": "object",
            "additionalProperties": false,
            "required": ["sha", "observed_at"],
            "properties": {
              "sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
              "observed_at": {"type": "string", "format": "date-time"}
            }
          }
        }
      }
    }
  }
}
