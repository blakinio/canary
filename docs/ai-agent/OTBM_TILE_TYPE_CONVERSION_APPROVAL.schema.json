{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "canary-otbm-tile-type-conversion-approval-v1",
  "title": "Canary OTBM tile type conversion approval v1",
  "type": "object",
  "$defs": {
    "pin": {
      "type": "object",
      "required": ["size", "sha256"],
      "properties": {
        "size": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "position": {
      "type": "array",
      "prefixItems": [
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"type": "integer", "minimum": 0, "maximum": 15}
      ],
      "minItems": 3,
      "maxItems": 3
    },
    "side": {
      "type": "object",
      "required": ["rawSha256", "rawByteLength", "nodeType", "canonicalSha256"],
      "properties": {
        "rawSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "rawByteLength": {"type": "integer", "minimum": 1},
        "nodeType": {"enum": [5, 14]},
        "canonicalSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    }
  },
  "required": ["format", "schemaVersion", "decision", "rationale", "provenance", "selections"],
  "properties": {
    "format": {"const": "canary-otbm-tile-type-conversion-approval-v1"},
    "schemaVersion": {"const": 1},
    "decision": {"const": "approved"},
    "rationale": {"type": "string", "minLength": 1},
    "provenance": {
      "type": "object",
      "required": ["current", "donor"],
      "properties": {
        "current": {
          "type": "object",
          "required": ["sourceMap", "worldIndex", "manifest"],
          "properties": {
            "sourceMap": {"$ref": "#/$defs/pin"},
            "worldIndex": {"$ref": "#/$defs/pin"},
            "manifest": {"$ref": "#/$defs/pin"}
          },
          "additionalProperties": false
        },
        "donor": {
          "type": "object",
          "required": ["sourceMap", "worldIndex", "manifest"],
          "properties": {
            "sourceMap": {"$ref": "#/$defs/pin"},
            "worldIndex": {"$ref": "#/$defs/pin"},
            "manifest": {"$ref": "#/$defs/pin"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "selections": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": {
        "type": "object",
        "required": ["position", "areaKey", "current", "donor"],
        "properties": {
          "position": {"$ref": "#/$defs/position"},
          "areaKey": {
            "type": "array",
            "prefixItems": [
              {"type": "integer", "minimum": 0, "maximum": 65535, "multipleOf": 256},
              {"type": "integer", "minimum": 0, "maximum": 65535, "multipleOf": 256},
              {"type": "integer", "minimum": 0, "maximum": 15}
            ],
            "minItems": 3,
            "maxItems": 3
          },
          "current": {"$ref": "#/$defs/side"},
          "donor": {"$ref": "#/$defs/side"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
