{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blakinio/canary/blob/main/docs/ai-agent/OTBM_MAP_QUALITY_GATE.schema.json",
  "title": "Canary OTBM static map quality gate report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schemaVersion",
    "ok",
    "source",
    "policy",
    "coverage",
    "components",
    "summary",
    "findings",
    "notes"
  ],
  "properties": {
    "format": {"const": "canary-otbm-map-quality-v1"},
    "schemaVersion": {"const": 1},
    "ok": {"type": "boolean"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256"],
      "properties": {
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readOnly",
        "mapModified",
        "otbmParsedIndependently",
        "gameplayCorrectnessProven",
        "playerIntentProven",
        "crossComponentDeduplication",
        "failOnSeverity",
        "failOnUnresolved",
        "sampleLimit"
      ],
      "properties": {
        "readOnly": {"const": true},
        "mapModified": {"const": false},
        "otbmParsedIndependently": {"const": false},
        "gameplayCorrectnessProven": {"const": false},
        "playerIntentProven": {"const": false},
        "crossComponentDeduplication": {"const": false},
        "failOnSeverity": {"enum": ["none", "error", "warning"]},
        "failOnUnresolved": {"type": "boolean"},
        "sampleLimit": {"type": "integer", "minimum": 1, "maximum": 10000}
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["geometry", "reachability", "sameRegion", "globalCoverageProven"],
      "properties": {
        "geometry": {"$ref": "#/$defs/nullableScope"},
        "reachability": {"$ref": "#/$defs/nullableScope"},
        "sameRegion": {"type": "boolean"},
        "globalCoverageProven": {"const": false}
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "required": ["geometry", "reachability", "scriptResolution"],
      "properties": {
        "geometry": {"$ref": "#/$defs/component"},
        "reachability": {"$ref": "#/$defs/component"},
        "scriptResolution": {
          "allOf": [
            {"$ref": "#/$defs/component"},
            {
              "type": "object",
              "properties": {
                "unreviewedIdentifiers": {"$ref": "#/$defs/nonNegative"},
                "unresolvedDynamicRegistrations": {"$ref": "#/$defs/nonNegative"}
              },
              "required": ["unreviewedIdentifiers", "unresolvedDynamicRegistrations"]
            }
          ]
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "outcomeCounts", "sampled", "truncated", "availableForSampling"],
      "properties": {
        "total": {"$ref": "#/$defs/nonNegative"},
        "outcomeCounts": {"$ref": "#/$defs/outcomeCounts"},
        "sampled": {"$ref": "#/$defs/nonNegative"},
        "truncated": {"type": "boolean"},
        "availableForSampling": {"$ref": "#/$defs/nonNegative"}
      }
    },
    "findings": {
      "type": "array",
      "maxItems": 10000,
      "items": {"$ref": "#/$defs/finding"}
    },
    "notes": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  },
  "$defs": {
    "nonNegative": {"type": "integer", "minimum": 0},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "position": {
      "type": "array",
      "prefixItems": [
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"type": "integer", "minimum": 0, "maximum": 15}
      ],
      "minItems": 3,
      "maxItems": 3
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": {"$ref": "#/$defs/position"},
        "to": {"$ref": "#/$defs/position"}
      }
    },
    "nullableScope": {
      "oneOf": [
        {"$ref": "#/$defs/scope"},
        {"type": "null"}
      ]
    },
    "outcomeCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["error", "warning", "unresolved", "info"],
      "properties": {
        "error": {"$ref": "#/$defs/nonNegative"},
        "warning": {"$ref": "#/$defs/nonNegative"},
        "unresolved": {"$ref": "#/$defs/nonNegative"},
        "info": {"$ref": "#/$defs/nonNegative"}
      }
    },
    "inputPin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fileName", "size", "sha256", "format"],
      "properties": {
        "fileName": {"type": "string", "minLength": 1},
        "size": {"$ref": "#/$defs/nonNegative"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "format": {"type": "string", "minLength": 1}
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "format",
        "sourceSha256",
        "input",
        "inputOk",
        "inputComplete",
        "outcomeCounts",
        "findingsAvailableForSampling",
        "findingsTruncatedByComponent"
      ],
      "properties": {
        "format": {"type": "string", "minLength": 1},
        "sourceSha256": {"$ref": "#/$defs/sha256"},
        "input": {"$ref": "#/$defs/inputPin"},
        "inputOk": {"type": "boolean"},
        "inputComplete": {"type": "boolean"},
        "outcomeCounts": {"$ref": "#/$defs/outcomeCounts"},
        "findingsAvailableForSampling": {"$ref": "#/$defs/nonNegative"},
        "findingsTruncatedByComponent": {"type": "boolean"}
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "component", "outcome", "kind", "message", "evidence"],
      "properties": {
        "id": {"type": "string", "pattern": "^[0-9a-f]{24}$"},
        "component": {"enum": ["geometry", "reachability", "scriptResolution"]},
        "outcome": {"enum": ["error", "warning", "unresolved", "info"]},
        "kind": {"type": "string", "minLength": 1},
        "message": {"type": "string"},
        "position": {"$ref": "#/$defs/position"},
        "sourceId": {"type": "string"},
        "evidence": {"type": "object"}
      }
    }
  }
}
