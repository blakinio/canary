{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blakinio/canary/blob/main/docs/ai-agent/OTBM_WORLD_HEALTH.schema.json",
  "title": "Canary OTBM deterministic world health report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schemaVersion",
    "source",
    "policy",
    "provenance",
    "coverage",
    "dimensions",
    "summary",
    "notes"
  ],
  "properties": {
    "format": {"const": "canary-otbm-world-health-v1"},
    "schemaVersion": {"const": 1},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mapSha256", "worldIndexSha256"],
      "properties": {
        "mapSha256": {"$ref": "#/$defs/sha256"},
        "worldIndexSha256": {
          "oneOf": [
            {"$ref": "#/$defs/sha256"},
            {"type": "null"}
          ]
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readOnly",
        "mapModified",
        "otbmParsedIndependently",
        "dynamicLuaExecuted",
        "crossDimensionDeduplication",
        "gameplayCorrectnessProven",
        "playerIntentProven",
        "globalAbsenceInferred",
        "healthScoreEmitted",
        "sampleLimitPerDimension"
      ],
      "properties": {
        "readOnly": {"const": true},
        "mapModified": {"const": false},
        "otbmParsedIndependently": {"const": false},
        "dynamicLuaExecuted": {"const": false},
        "crossDimensionDeduplication": {"const": false},
        "gameplayCorrectnessProven": {"const": false},
        "playerIntentProven": {"const": false},
        "globalAbsenceInferred": {"const": false},
        "healthScoreEmitted": {"const": false},
        "sampleLimitPerDimension": {"type": "integer", "minimum": 1, "maximum": 10000}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mapQuality", "reachability", "coverageMatrices"],
      "properties": {
        "mapQuality": {"$ref": "#/$defs/mapQualityProvenance"},
        "reachability": {
          "type": "array",
          "items": {"$ref": "#/$defs/reachabilityProvenance"}
        },
        "coverageMatrices": {
          "type": "array",
          "items": {"$ref": "#/$defs/coverageProvenance"}
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mapQuality", "reachabilityRegions", "coverageMatrixCount", "globalCoverageProven"],
      "properties": {
        "mapQuality": {
          "type": "object",
          "additionalProperties": false,
          "required": ["geometry", "reachability", "sameRegion", "globalCoverageProven"],
          "properties": {
            "geometry": {"$ref": "#/$defs/nullableScope"},
            "reachability": {"$ref": "#/$defs/nullableScope"},
            "sameRegion": {"type": "boolean"},
            "globalCoverageProven": {"const": false}
          }
        },
        "reachabilityRegions": {
          "type": "array",
          "items": {"$ref": "#/$defs/reachabilityRegion"}
        },
        "coverageMatrixCount": {"$ref": "#/$defs/nonNegative"},
        "globalCoverageProven": {"const": false}
      }
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["structural", "runtimeHandlers", "reachability", "staleEvidence", "missingPhysicalCoverage"],
      "properties": {
        "structural": {"$ref": "#/$defs/structuralDimension"},
        "runtimeHandlers": {"$ref": "#/$defs/runtimeDimension"},
        "reachability": {"$ref": "#/$defs/reachabilityDimension"},
        "staleEvidence": {"$ref": "#/$defs/simpleDimension"},
        "missingPhysicalCoverage": {"$ref": "#/$defs/missingPhysicalDimension"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "structuralFindings",
        "runtimeHandlerPlacementFindings",
        "attentionMechanics",
        "staleEvidenceTargets",
        "missingPhysicalScenarioTargets",
        "runtimeNotProvenOnCurrentMapTargets"
      ],
      "properties": {
        "structuralFindings": {"$ref": "#/$defs/nonNegative"},
        "runtimeHandlerPlacementFindings": {"$ref": "#/$defs/nonNegative"},
        "attentionMechanics": {"$ref": "#/$defs/nonNegative"},
        "staleEvidenceTargets": {"$ref": "#/$defs/nonNegative"},
        "missingPhysicalScenarioTargets": {"$ref": "#/$defs/nonNegative"},
        "runtimeNotProvenOnCurrentMapTargets": {"$ref": "#/$defs/nonNegative"}
      }
    },
    "notes": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  },
  "$defs": {
    "nonNegative": {"type": "integer", "minimum": 0},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "position": {
      "type": "array",
      "prefixItems": [
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"type": "integer", "minimum": 0, "maximum": 15}
      ],
      "minItems": 3,
      "maxItems": 3
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": {"$ref": "#/$defs/position"},
        "to": {"$ref": "#/$defs/position"}
      }
    },
    "nullableScope": {
      "oneOf": [
        {"$ref": "#/$defs/scope"},
        {"type": "null"}
      ]
    },
    "inputPin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fileName", "size", "sha256", "format"],
      "properties": {
        "fileName": {"type": "string", "minLength": 1},
        "size": {"$ref": "#/$defs/nonNegative"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "format": {"type": "string", "minLength": 1}
      }
    },
    "outcomeCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["error", "warning", "unresolved", "info"],
      "properties": {
        "error": {"$ref": "#/$defs/nonNegative"},
        "warning": {"$ref": "#/$defs/nonNegative"},
        "unresolved": {"$ref": "#/$defs/nonNegative"},
        "info": {"$ref": "#/$defs/nonNegative"}
      }
    },
    "statusCounts": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/nonNegative"}
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "dimension", "kind", "status", "sourceFormat", "sourceReportSha256", "evidence"],
      "properties": {
        "id": {"type": "string", "pattern": "^[0-9a-f]{24}$"},
        "dimension": {
          "enum": ["structural", "runtimeHandlers", "reachability", "staleEvidence", "missingPhysicalCoverage"]
        },
        "kind": {"type": "string", "minLength": 1},
        "status": {"type": "string", "minLength": 1},
        "sourceFormat": {"type": "string", "minLength": 1},
        "sourceReportSha256": {"$ref": "#/$defs/sha256"},
        "position": {"$ref": "#/$defs/position"},
        "sourceId": {"type": "string"},
        "evidence": {"type": "object", "additionalProperties": true}
      }
    },
    "sampleState": {
      "type": "object",
      "required": ["sampled", "truncated", "outputSampleTruncated", "sourceEvidenceTruncated", "samples"],
      "properties": {
        "sampled": {"$ref": "#/$defs/nonNegative"},
        "truncated": {"type": "boolean"},
        "outputSampleTruncated": {"type": "boolean"},
        "sourceEvidenceTruncated": {"type": "boolean"},
        "samples": {
          "type": "array",
          "maxItems": 10000,
          "items": {"$ref": "#/$defs/sample"}
        }
      }
    },
    "structuralDimension": {
      "allOf": [
        {"$ref": "#/$defs/sampleState"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "evidencePresent",
            "total",
            "outcomeCounts",
            "sampled",
            "truncated",
            "outputSampleTruncated",
            "sourceEvidenceTruncated",
            "samples"
          ],
          "properties": {
            "evidencePresent": {"const": true},
            "total": {"$ref": "#/$defs/nonNegative"},
            "outcomeCounts": {"$ref": "#/$defs/outcomeCounts"},
            "sampled": {"$ref": "#/$defs/nonNegative"},
            "truncated": {"type": "boolean"},
            "outputSampleTruncated": {"type": "boolean"},
            "sourceEvidenceTruncated": {"type": "boolean"},
            "samples": {"type": "array", "maxItems": 10000, "items": {"$ref": "#/$defs/sample"}}
          }
        }
      ]
    },
    "runtimeDimension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidencePresent",
        "placementFindingsTotal",
        "outcomeCounts",
        "conflictingPlacements",
        "unresolvedPlacements",
        "unreviewedIdentifiers",
        "unresolvedDynamicRegistrations",
        "sampled",
        "truncated",
        "outputSampleTruncated",
        "sourceEvidenceTruncated",
        "samples"
      ],
      "properties": {
        "evidencePresent": {"const": true},
        "placementFindingsTotal": {"$ref": "#/$defs/nonNegative"},
        "outcomeCounts": {"$ref": "#/$defs/outcomeCounts"},
        "conflictingPlacements": {"$ref": "#/$defs/nonNegative"},
        "unresolvedPlacements": {"$ref": "#/$defs/nonNegative"},
        "unreviewedIdentifiers": {"$ref": "#/$defs/nonNegative"},
        "unresolvedDynamicRegistrations": {"$ref": "#/$defs/nonNegative"},
        "sampled": {"$ref": "#/$defs/nonNegative"},
        "truncated": {"type": "boolean"},
        "outputSampleTruncated": {"type": "boolean"},
        "sourceEvidenceTruncated": {"type": "boolean"},
        "samples": {"type": "array", "maxItems": 10000, "items": {"$ref": "#/$defs/sample"}}
      }
    },
    "reachabilityDimension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidencePresent",
        "reportCount",
        "routes",
        "transitions",
        "mechanics",
        "tiles",
        "sampled",
        "truncated",
        "outputSampleTruncated",
        "sourceEvidenceTruncated",
        "samples"
      ],
      "properties": {
        "evidencePresent": {"type": "boolean"},
        "reportCount": {"$ref": "#/$defs/nonNegative"},
        "routes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["total", "statusCounts"],
          "properties": {
            "total": {"$ref": "#/$defs/nonNegative"},
            "statusCounts": {"$ref": "#/$defs/statusCounts"}
          }
        },
        "transitions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["total", "statusCounts", "oneWay", "deadEnd", "loops"],
          "properties": {
            "total": {"$ref": "#/$defs/nonNegative"},
            "statusCounts": {"$ref": "#/$defs/statusCounts"},
            "oneWay": {"$ref": "#/$defs/nonNegative"},
            "deadEnd": {"$ref": "#/$defs/nonNegative"},
            "loops": {"$ref": "#/$defs/nonNegative"}
          }
        },
        "mechanics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["total", "statusCounts", "attentionTotal"],
          "properties": {
            "total": {"$ref": "#/$defs/nonNegative"},
            "statusCounts": {"$ref": "#/$defs/statusCounts"},
            "attentionTotal": {"$ref": "#/$defs/nonNegative"}
          }
        },
        "tiles": {
          "type": "object",
          "additionalProperties": false,
          "required": ["statusCounts"],
          "properties": {
            "statusCounts": {"$ref": "#/$defs/statusCounts"}
          }
        },
        "sampled": {"$ref": "#/$defs/nonNegative"},
        "truncated": {"type": "boolean"},
        "outputSampleTruncated": {"type": "boolean"},
        "sourceEvidenceTruncated": {"type": "boolean"},
        "samples": {"type": "array", "maxItems": 10000, "items": {"$ref": "#/$defs/sample"}}
      }
    },
    "simpleDimension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidencePresent",
        "reportCount",
        "total",
        "sampled",
        "truncated",
        "outputSampleTruncated",
        "sourceEvidenceTruncated",
        "samples"
      ],
      "properties": {
        "evidencePresent": {"type": "boolean"},
        "reportCount": {"$ref": "#/$defs/nonNegative"},
        "total": {"$ref": "#/$defs/nonNegative"},
        "sampled": {"$ref": "#/$defs/nonNegative"},
        "truncated": {"type": "boolean"},
        "outputSampleTruncated": {"type": "boolean"},
        "sourceEvidenceTruncated": {"type": "boolean"},
        "samples": {"type": "array", "maxItems": 10000, "items": {"$ref": "#/$defs/sample"}}
      }
    },
    "missingPhysicalDimension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidencePresent",
        "reportCount",
        "targets",
        "total",
        "missingScenarioTotal",
        "runtimeNotProvenOnCurrentMapTotal",
        "sampled",
        "truncated",
        "outputSampleTruncated",
        "sourceEvidenceTruncated",
        "samples"
      ],
      "properties": {
        "evidencePresent": {"type": "boolean"},
        "reportCount": {"$ref": "#/$defs/nonNegative"},
        "targets": {"$ref": "#/$defs/nonNegative"},
        "total": {"$ref": "#/$defs/nonNegative"},
        "missingScenarioTotal": {"$ref": "#/$defs/nonNegative"},
        "runtimeNotProvenOnCurrentMapTotal": {"$ref": "#/$defs/nonNegative"},
        "sampled": {"$ref": "#/$defs/nonNegative"},
        "truncated": {"type": "boolean"},
        "outputSampleTruncated": {"type": "boolean"},
        "sourceEvidenceTruncated": {"type": "boolean"},
        "samples": {"type": "array", "maxItems": 10000, "items": {"$ref": "#/$defs/sample"}}
      }
    },
    "mapQualityProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input", "sourceMapSha256"],
      "properties": {
        "input": {"$ref": "#/$defs/inputPin"},
        "sourceMapSha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "reachabilityRegion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "coordinateCount", "indexedTileCount"],
      "properties": {
        "from": {"$ref": "#/$defs/position"},
        "to": {"$ref": "#/$defs/position"},
        "coordinateCount": {"$ref": "#/$defs/nonNegative"},
        "indexedTileCount": {"$ref": "#/$defs/nonNegative"}
      }
    },
    "reachabilityProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input", "sourceMapSha256", "worldIndexSha256", "region", "inputOk"],
      "properties": {
        "input": {"$ref": "#/$defs/inputPin"},
        "sourceMapSha256": {"$ref": "#/$defs/sha256"},
        "worldIndexSha256": {"$ref": "#/$defs/sha256"},
        "region": {"$ref": "#/$defs/reachabilityRegion"},
        "inputOk": {"type": "boolean"}
      }
    },
    "coverageProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input", "sourceMapSha256", "worldIndexSha256", "targets"],
      "properties": {
        "input": {"$ref": "#/$defs/inputPin"},
        "sourceMapSha256": {"$ref": "#/$defs/sha256"},
        "worldIndexSha256": {"$ref": "#/$defs/sha256"},
        "targets": {"$ref": "#/$defs/nonNegative"}
      }
    }
  }
}
