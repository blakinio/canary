{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blakinio/canary/blob/main/docs/ai-agent/OTBM_REPAIR_SANDBOX_REPORT.schema.json",
  "title": "Canary OTBM repair sandbox verification report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "ok",
    "source",
    "patchedOutput",
    "phase8",
    "inputs",
    "summary",
    "operations",
    "review",
    "policy",
    "notes"
  ],
  "properties": {
    "format": {"const": "canary-otbm-repair-sandbox-verification-v1"},
    "ok": {"const": true},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fileName", "sha256", "size", "unchanged"],
      "properties": {
        "fileName": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "size": {"type": "integer", "minimum": 1},
        "unchanged": {"const": true}
      }
    },
    "patchedOutput": {
      "type": "object",
      "required": ["path", "size", "sha256", "atomicCopyOnly"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "size": {"type": "integer", "minimum": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "atomicCopyOnly": {"const": true}
      }
    },
    "phase8": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "plan", "proof", "evidence"],
      "properties": {
        "format": {"const": "canary-otbm-bounded-patch-result-v1"},
        "plan": {"type": "object"},
        "proof": {
          "type": "object",
          "required": [
            "fileLengthPreserved",
            "outsideScannerSpansEqual",
            "fullScannerReparse",
            "worldIndexBeforeAfterBuilt",
            "boundedSemanticDiffExact"
          ],
          "properties": {
            "fileLengthPreserved": {"const": true},
            "outsideScannerSpansEqual": {"const": true},
            "fullScannerReparse": {"const": true},
            "worldIndexBeforeAfterBuilt": {"const": true},
            "boundedSemanticDiffExact": {"const": true}
          }
        },
        "evidence": {"type": "object"}
      }
    },
    "inputs": {"type": "object"},
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operations",
        "runtimeResolutionChangedOperations",
        "runtimeRegressionOperations",
        "runtimeUnresolvedAfter",
        "runtimeConflictingAfter",
        "beforeStatusCounts",
        "afterStatusCounts"
      ],
      "properties": {
        "operations": {"type": "integer", "minimum": 1},
        "runtimeResolutionChangedOperations": {"type": "integer", "minimum": 0},
        "runtimeRegressionOperations": {"type": "integer", "minimum": 0},
        "runtimeUnresolvedAfter": {"type": "integer", "minimum": 0},
        "runtimeConflictingAfter": {"type": "integer", "minimum": 0},
        "beforeStatusCounts": {"$ref": "#/$defs/statusCounts"},
        "afterStatusCounts": {"$ref": "#/$defs/statusCounts"}
      }
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000,
      "items": {"$ref": "#/$defs/operation"}
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiresHumanReview",
        "runtimeRegressionObserved",
        "unresolvedEvidencePreserved",
        "gameplayCorrectnessProven",
        "playerIntentProven",
        "reachabilityProven",
        "physicalClientE2EProven"
      ],
      "properties": {
        "requiresHumanReview": {"const": true},
        "runtimeRegressionObserved": {"type": "boolean"},
        "unresolvedEvidencePreserved": {"const": true},
        "gameplayCorrectnessProven": {"const": false},
        "playerIntentProven": {"const": false},
        "reachabilityProven": {"const": false},
        "physicalClientE2EProven": {"const": false}
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceModifiedInPlace",
        "sandboxCopyOnly",
        "newOtbmParserCreated",
        "newOtbmWriterCreated",
        "phase8BoundedPatcherReused",
        "phase8WorldIndexProofReused",
        "phase8SemanticDiffProofReused",
        "mapQualityGateAutoGenerated"
      ],
      "properties": {
        "sourceModifiedInPlace": {"const": false},
        "sandboxCopyOnly": {"const": true},
        "newOtbmParserCreated": {"const": false},
        "newOtbmWriterCreated": {"const": false},
        "phase8BoundedPatcherReused": {"const": true},
        "phase8WorldIndexProofReused": {"const": true},
        "phase8SemanticDiffProofReused": {"const": true},
        "mapQualityGateAutoGenerated": {"const": false}
      }
    },
    "notes": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "position": {
      "type": "array",
      "prefixItems": [
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"type": "integer", "minimum": 0, "maximum": 15}
      ],
      "minItems": 3,
      "maxItems": 3
    },
    "statusCounts": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 0}
    },
    "runtimeDiff": {
      "type": "object",
      "required": ["changed", "beforeFingerprint", "afterFingerprint", "changes"],
      "properties": {
        "changed": {"type": "boolean"},
        "beforeFingerprint": {"$ref": "#/$defs/sha256"},
        "afterFingerprint": {"$ref": "#/$defs/sha256"},
        "changes": {"type": "array"}
      }
    },
    "side": {
      "type": "object",
      "required": ["auditIndex", "placement", "runtimeStatus", "scriptResolution"],
      "properties": {
        "auditIndex": {"type": "integer", "minimum": 0},
        "placement": {"type": "object"},
        "runtimeStatus": {"type": "string", "minLength": 1},
        "scriptResolution": {"type": "object"}
      }
    },
    "operation": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "position",
        "tilePlacementIndex",
        "itemId",
        "itemDepth",
        "attribute",
        "expected",
        "replacement",
        "before",
        "after",
        "runtimeResolutionChanged",
        "runtimeRegression",
        "replacementRuntimeResolved",
        "runtimeDiff"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "kind": {"enum": ["set-action-id", "set-unique-id", "set-house-door-id", "set-teleport-destination"]},
        "position": {"$ref": "#/$defs/position"},
        "tilePlacementIndex": {"type": "integer", "minimum": 0},
        "itemId": {"type": "integer", "minimum": 0, "maximum": 65535},
        "itemDepth": {"type": "integer", "minimum": 0},
        "attribute": {"enum": ["actionId", "uniqueId", "houseDoorId", "teleportDestination"]},
        "expected": {},
        "replacement": {},
        "before": {"$ref": "#/$defs/side"},
        "after": {"$ref": "#/$defs/side"},
        "runtimeResolutionChanged": {"type": "boolean"},
        "runtimeRegression": {"type": "boolean"},
        "replacementRuntimeResolved": {"type": "boolean"},
        "runtimeDiff": {"$ref": "#/$defs/runtimeDiff"}
      }
    }
  }
}
