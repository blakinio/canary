{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "canary-otbm-tile-insertion-result-v1",
  "title": "Canary OTBM tile insertion result v1",
  "type": "object",
  "required": ["format", "schemaVersion", "ok", "structuralVerificationComplete", "source", "approval", "selection", "rawConfinement", "insertedWorldIndex", "verification", "rollback", "safety"],
  "properties": {
    "format": {"const": "canary-otbm-tile-insertion-result-v1"},
    "schemaVersion": {"const": 1},
    "ok": {"const": true},
    "structuralVerificationComplete": {"const": true},
    "source": {"type": "object"},
    "approval": {
      "type": "object",
      "required": ["path", "sha256", "format"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "format": {"const": "canary-otbm-tile-insertion-approval-v1"}
      },
      "additionalProperties": false
    },
    "selection": {
      "type": "object",
      "required": ["positions", "count", "translation", "operation"],
      "properties": {
        "positions": {"type": "array", "minItems": 1, "maxItems": 4096},
        "count": {"type": "integer", "minimum": 1, "maximum": 4096},
        "translation": {"const": [0, 0, 0]},
        "operation": {"const": "insert-missing-same-coordinate-tile"}
      },
      "additionalProperties": false
    },
    "rawConfinement": {"type": "object"},
    "insertedWorldIndex": {"type": "array", "minItems": 1, "maxItems": 4096},
    "verification": {
      "type": "object",
      "required": ["nativeReparse", "worldIndexRebuilt", "insertedTilesEqualDonor", "completeCurrentByteSequenceExact", "semanticDiff"],
      "properties": {
        "nativeReparse": {"const": true},
        "worldIndexRebuilt": {"const": true},
        "insertedTilesEqualDonor": {"const": true},
        "completeCurrentByteSequenceExact": {"const": true},
        "semanticDiff": {"type": "object"}
      }
    },
    "rollback": {"type": "object"},
    "safety": {
      "type": "object",
      "required": ["sourceInPlaceWrite", "fullMapSerializer", "translatedImport", "tileInsertion", "tileDeletion", "tileAreaCreation", "itemStackEditing", "arbitraryNodeSerialization", "rawCompleteTileSubtreesOnly", "sameCoordinateOnly", "existingParentTileAreaOnly", "separateApprovalRequired", "gameplayCorrectnessProven", "physicalClientE2EProven"],
      "properties": {
        "sourceInPlaceWrite": {"const": false},
        "fullMapSerializer": {"const": false},
        "translatedImport": {"const": false},
        "tileInsertion": {"const": true},
        "tileDeletion": {"const": false},
        "tileAreaCreation": {"const": false},
        "itemStackEditing": {"const": false},
        "arbitraryNodeSerialization": {"const": false},
        "rawCompleteTileSubtreesOnly": {"const": true},
        "sameCoordinateOnly": {"const": true},
        "existingParentTileAreaOnly": {"const": true},
        "separateApprovalRequired": {"const": true},
        "gameplayCorrectnessProven": {"const": false},
        "physicalClientE2EProven": {"const": false}
      },
      "additionalProperties": false
    }
  }
}
