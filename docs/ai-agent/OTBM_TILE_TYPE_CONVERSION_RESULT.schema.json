{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "canary-otbm-tile-type-conversion-result-v1",
  "title": "Canary OTBM tile type conversion result v1",
  "type": "object",
  "required": ["format", "schemaVersion", "ok", "structuralVerificationComplete", "source", "approval", "selection", "rawConfinement", "selectedWorldIndex", "verification", "rollback", "safety"],
  "properties": {
    "format": {"const": "canary-otbm-tile-type-conversion-result-v1"},
    "schemaVersion": {"const": 1},
    "ok": {"const": true},
    "structuralVerificationComplete": {"const": true},
    "source": {"type": "object"},
    "approval": {
      "type": "object",
      "required": ["path", "sha256", "format", "decision"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "format": {"const": "canary-otbm-tile-type-conversion-approval-v1"},
        "decision": {"const": "approved"}
      },
      "additionalProperties": false
    },
    "selection": {
      "type": "object",
      "required": ["positions", "count", "translation", "operation", "conversions"],
      "properties": {
        "positions": {"type": "array", "minItems": 1, "maxItems": 4096},
        "count": {"type": "integer", "minimum": 1, "maximum": 4096},
        "translation": {"const": [0, 0, 0]},
        "operation": {"const": "convert-existing-same-coordinate-tile-type"},
        "conversions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4096,
          "items": {
            "type": "object",
            "required": ["position", "areaKey", "fromNodeType", "toNodeType", "fromKind", "toKind"],
            "properties": {
              "position": {"type": "array", "minItems": 3, "maxItems": 3},
              "areaKey": {"type": "array", "minItems": 3, "maxItems": 3},
              "fromNodeType": {"enum": [5, 14]},
              "toNodeType": {"enum": [5, 14]},
              "fromKind": {"enum": ["tile", "house"]},
              "toKind": {"enum": ["tile", "house"]}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "rawConfinement": {"type": "object"},
    "selectedWorldIndex": {"type": "array", "minItems": 1, "maxItems": 4096},
    "verification": {
      "type": "object",
      "required": ["nativeReparse", "worldIndexRebuilt", "selectedTilesEqualDonor", "nonSelectedCurrentBytesExact", "semanticDiff"],
      "properties": {
        "nativeReparse": {"const": true},
        "worldIndexRebuilt": {"const": true},
        "selectedTilesEqualDonor": {"const": true},
        "nonSelectedCurrentBytesExact": {"const": true},
        "semanticDiff": {"type": "object"}
      }
    },
    "rollback": {"type": "object"},
    "safety": {
      "type": "object",
      "required": ["sourceInPlaceWrite", "fullMapSerializer", "phase8Expanded", "translatedImport", "tileInsertion", "tileDeletion", "tileTypeConversion", "itemStackEditing", "arbitraryNodeSerialization", "rawCompleteTileSubtreesOnly", "sameCoordinateOnly", "sameParentTileAreaOnly", "sameNodeTypeOnly", "separateApprovalRequired", "gameplayCorrectnessProven", "physicalClientE2EProven"],
      "properties": {
        "sourceInPlaceWrite": {"const": false},
        "fullMapSerializer": {"const": false},
        "phase8Expanded": {"const": false},
        "translatedImport": {"const": false},
        "tileInsertion": {"const": false},
        "tileDeletion": {"const": false},
        "tileTypeConversion": {"const": true},
        "itemStackEditing": {"const": false},
        "arbitraryNodeSerialization": {"const": false},
        "rawCompleteTileSubtreesOnly": {"const": true},
        "sameCoordinateOnly": {"const": true},
        "sameParentTileAreaOnly": {"const": true},
        "sameNodeTypeOnly": {"const": false},
        "separateApprovalRequired": {"const": true},
        "gameplayCorrectnessProven": {"const": false},
        "physicalClientE2EProven": {"const": false}
      },
      "additionalProperties": false
    }
  }
}
