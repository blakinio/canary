{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blakinio/canary/docs/ai-agent/OTBM_RUNTIME_INCIDENT_EVIDENCE_BINDINGS.schema.json",
  "title": "Canary OTBM Runtime Incident Evidence Bindings v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "schemaVersion", "bindings"],
  "properties": {
    "format": {"const": "canary-otbm-runtime-incident-evidence-bindings-v1"},
    "schemaVersion": {"const": 1},
    "bindings": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {"$ref": "#/$defs/binding"}
    }
  },
  "$defs": {
    "position": {
      "type": "array",
      "prefixItems": [
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"type": "integer", "minimum": 0, "maximum": 15}
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    },
    "selector": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value"],
          "properties": {
            "kind": {"const": "position"},
            "value": {"$ref": "#/$defs/position"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value"],
          "properties": {
            "kind": {"enum": ["transition-id", "interaction-id", "landmark-id", "route-id", "preflight-reference"]},
            "value": {"type": "string", "minLength": 1}
          }
        }
      ]
    },
    "extract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "pointer"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "pointer": {"type": "string"}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "sha256", "format", "extracts"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
        "format": {"type": "string", "minLength": 1},
        "extracts": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/extract"}
        }
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "selector", "sources"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "selector": {"$ref": "#/$defs/selector"},
        "sources": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": {"$ref": "#/$defs/source"}
        },
        "contextReferences": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
