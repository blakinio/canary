{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "canary-otbm-identifier-integrity-v1",
  "title": "Canary OTBM Identifier Integrity Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schemaVersion",
    "ok",
    "source",
    "policy",
    "summary",
    "expectations",
    "reviewRequired",
    "scriptConflicts",
    "scriptUnresolved",
    "transitionConflicts",
    "selectorAmbiguities",
    "roleConflicts",
    "conflicts",
    "inputPins",
    "notes"
  ],
  "properties": {
    "format": {"const": "canary-otbm-identifier-integrity-v1"},
    "schemaVersion": {"const": 1},
    "ok": {"type": "boolean"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mapSha256", "worldIndexSha256"],
      "properties": {
        "mapSha256": {"$ref": "#/$defs/sha256"},
        "worldIndexSha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "expectationCount", "placementRoleCount"],
      "properties": {
        "format": {"const": "canary-otbm-identifier-integrity-policy-v1"},
        "expectationCount": {"type": "integer", "minimum": 0},
        "placementRoleCount": {"type": "integer", "minimum": 0}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mechanicPlacements",
        "identifierValues",
        "repeatedIdentifierValues",
        "reviewedExpectations",
        "reviewedReuse",
        "reviewRequired",
        "scriptConflicts",
        "scriptUnresolved",
        "transitionConflicts",
        "selectorAmbiguities",
        "roleConflicts",
        "conflicts"
      ],
      "properties": {
        "mechanicPlacements": {"type": "integer", "minimum": 0},
        "identifierValues": {"$ref": "#/$defs/counts"},
        "repeatedIdentifierValues": {"$ref": "#/$defs/counts"},
        "reviewedExpectations": {"type": "integer", "minimum": 0},
        "reviewedReuse": {"type": "integer", "minimum": 0},
        "reviewRequired": {"type": "integer", "minimum": 0},
        "scriptConflicts": {"type": "integer", "minimum": 0},
        "scriptUnresolved": {"type": "integer", "minimum": 0},
        "transitionConflicts": {"type": "integer", "minimum": 0},
        "selectorAmbiguities": {"type": "integer", "minimum": 0},
        "roleConflicts": {"type": "integer", "minimum": 0},
        "conflicts": {"type": "integer", "minimum": 0}
      }
    },
    "expectations": {"type": "array", "items": {"type": "object"}},
    "reviewRequired": {"type": "array", "items": {"type": "object"}},
    "scriptConflicts": {"type": "array", "items": {"type": "object"}},
    "scriptUnresolved": {"type": "array", "items": {"type": "object"}},
    "transitionConflicts": {"type": "array", "items": {"type": "object"}},
    "selectorAmbiguities": {"type": "array", "items": {"type": "object"}},
    "roleConflicts": {"type": "array", "items": {"type": "object"}},
    "conflicts": {"type": "array", "items": {"type": "object"}},
    "inputPins": {"type": "object"},
    "notes": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actionId", "houseDoorId", "uniqueId"],
      "properties": {
        "actionId": {"type": "integer", "minimum": 0},
        "houseDoorId": {"type": "integer", "minimum": 0},
        "uniqueId": {"type": "integer", "minimum": 0}
      }
    }
  }
}
