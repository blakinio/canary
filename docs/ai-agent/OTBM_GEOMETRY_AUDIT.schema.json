{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://canary.example/schemas/OTBM_GEOMETRY_AUDIT.schema.json",
  "title": "Canary bounded OTBM geometry audit",
  "$defs": {
    "position": {
      "type": "array",
      "prefixItems": [
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"type": "integer", "minimum": 0, "maximum": 15}
      ],
      "items": false
    },
    "finding": {
      "type": "object",
      "required": ["id", "kind", "severity", "confidence", "message"],
      "properties": {
        "id": {"type": "string", "pattern": "^[0-9a-f]{24}$"},
        "kind": {"type": "string", "minLength": 1, "maxLength": 120},
        "severity": {"enum": ["error", "warning", "info"]},
        "confidence": {"enum": ["high", "medium", "low"]},
        "message": {"type": "string", "minLength": 1},
        "position": {"$ref": "#/$defs/position"}
      },
      "additionalProperties": true
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schemaVersion",
    "ok",
    "complete",
    "policy",
    "scope",
    "provenance",
    "summary",
    "rules",
    "findings"
  ],
  "properties": {
    "format": {"const": "canary-otbm-geometry-audit-v1"},
    "schemaVersion": {"const": 1},
    "ok": {"type": "boolean"},
    "complete": {"const": true},
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readOnly",
        "otbmParsedIndependently",
        "phase3ClassifierReused",
        "dynamicLuaExecuted",
        "visualIntentInferred",
        "wallBorderRulesRequired",
        "protectionZoneMask",
        "mapModified",
        "aiImageryUsed",
        "scopeIsGlobal"
      ],
      "properties": {
        "readOnly": {"const": true},
        "otbmParsedIndependently": {"const": false},
        "phase3ClassifierReused": {"const": true},
        "dynamicLuaExecuted": {"const": false},
        "visualIntentInferred": {"const": false},
        "wallBorderRulesRequired": {"const": true},
        "protectionZoneMask": {"const": 1},
        "mapModified": {"const": false},
        "aiImageryUsed": {"const": false},
        "scopeIsGlobal": {"const": false}
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "coordinateCount", "orphanMaxTiles", "sampleLimit"],
      "properties": {
        "from": {"$ref": "#/$defs/position"},
        "to": {"$ref": "#/$defs/position"},
        "coordinateCount": {"type": "integer", "minimum": 1, "maximum": 1000000},
        "orphanMaxTiles": {"type": "integer", "minimum": 1, "maximum": 10000},
        "sampleLimit": {"type": "integer", "minimum": 1, "maximum": 10000}
      }
    },
    "provenance": {
      "type": "object",
      "required": ["index", "manifest", "source", "scanner", "otbm", "worldSummary", "appearances", "geometryRules"],
      "additionalProperties": true,
      "properties": {
        "geometryRules": {"type": ["object", "null"]}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tiles",
        "placements",
        "tileComponents",
        "orphanCandidateComponents",
        "houses",
        "disconnectedHouses",
        "houseComponentsWithMixedPz",
        "protectionZoneTiles",
        "protectionZoneComponents",
        "isolatedProtectionZoneTiles",
        "protectionZoneEnclosedGaps",
        "invisibleBlockerCandidates",
        "unknownAppearancePlacementsByItemId",
        "adjacencyRules",
        "adjacencyChecks",
        "findings"
      ],
      "properties": {
        "tiles": {"type": "integer", "minimum": 0},
        "placements": {"type": "integer", "minimum": 0},
        "tileComponents": {"type": "integer", "minimum": 0},
        "orphanCandidateComponents": {"type": "integer", "minimum": 0},
        "houses": {"type": "integer", "minimum": 0},
        "disconnectedHouses": {"type": "integer", "minimum": 0},
        "houseComponentsWithMixedPz": {"type": "integer", "minimum": 0},
        "protectionZoneTiles": {"type": "integer", "minimum": 0},
        "protectionZoneComponents": {"type": "integer", "minimum": 0},
        "isolatedProtectionZoneTiles": {"type": "integer", "minimum": 0},
        "protectionZoneEnclosedGaps": {"type": "integer", "minimum": 0},
        "invisibleBlockerCandidates": {"type": "integer", "minimum": 0},
        "unknownAppearancePlacementsByItemId": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["itemId", "placements"],
            "properties": {
              "itemId": {"type": "integer", "minimum": 0, "maximum": 65535},
              "placements": {"type": "integer", "minimum": 1}
            }
          }
        },
        "adjacencyRules": {"type": "integer", "minimum": 0},
        "adjacencyChecks": {"type": "integer", "minimum": 0},
        "findings": {
          "type": "object",
          "additionalProperties": false,
          "required": ["total", "byKind", "bySeverity", "byConfidence", "sampled", "truncated"],
          "properties": {
            "total": {"type": "integer", "minimum": 0},
            "byKind": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
            "bySeverity": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
            "byConfidence": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
            "sampled": {"type": "integer", "minimum": 0},
            "truncated": {"type": "boolean"}
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "maxItems": 10000,
      "items": {"type": "object"}
    },
    "findings": {
      "type": "array",
      "maxItems": 10000,
      "items": {"$ref": "#/$defs/finding"}
    }
  }
}
