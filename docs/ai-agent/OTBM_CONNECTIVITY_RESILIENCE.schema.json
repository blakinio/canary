{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blakinio/canary/blob/main/docs/ai-agent/OTBM_CONNECTIVITY_RESILIENCE.schema.json",
  "title": "Canary OTBM connectivity resilience report",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "schemaVersion", "ok", "source", "region", "inputs", "policy", "canonicalReachabilityValidation", "summary", "routes", "entrapmentTargets", "topology", "findings"],
  "properties": {
    "format": {"const": "canary-otbm-connectivity-resilience-v1"},
    "schemaVersion": {"const": 1},
    "ok": {"type": "boolean"},
    "source": {"$ref": "#/$defs/source"},
    "region": {"$ref": "#/$defs/region"},
    "inputs": {"type": "object"},
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonicalReachabilityBfsReused", "canonicalMovementNeighborsReused", "canonicalTransitionEdgesReused", "canonicalCycleDetectionReused", "secondPathfinderImplemented", "dynamicLuaExecuted", "runtimeEntrapmentClaimed", "globalConnectivityClaimed", "physicalE2EExecuted"],
      "properties": {
        "canonicalReachabilityBfsReused": {"const": true},
        "canonicalMovementNeighborsReused": {"const": true},
        "canonicalTransitionEdgesReused": {"const": true},
        "canonicalCycleDetectionReused": {"const": true},
        "secondPathfinderImplemented": {"const": false},
        "dynamicLuaExecuted": {"const": false},
        "runtimeEntrapmentClaimed": {"const": false},
        "globalConnectivityClaimed": {"const": false},
        "physicalE2EExecuted": {"const": false}
      }
    },
    "canonicalReachabilityValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["findings", "summary"],
      "properties": {
        "findings": {"type": "array", "items": {"type": "object"}},
        "summary": {"type": "object"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["routeCount", "reachableRouteCount", "singleEdgeFragileRouteCount", "edgeDisjointAlternativeRouteCount", "conditionalOnlyRouteCount", "entrapmentTargetCount", "staticEntrapmentCandidateCount", "findingCount"],
      "properties": {
        "routeCount": {"$ref": "#/$defs/count"},
        "reachableRouteCount": {"$ref": "#/$defs/count"},
        "singleEdgeFragileRouteCount": {"$ref": "#/$defs/count"},
        "edgeDisjointAlternativeRouteCount": {"$ref": "#/$defs/count"},
        "conditionalOnlyRouteCount": {"$ref": "#/$defs/count"},
        "entrapmentTargetCount": {"$ref": "#/$defs/count"},
        "staticEntrapmentCandidateCount": {"$ref": "#/$defs/count"},
        "findingCount": {"$ref": "#/$defs/count"}
      }
    },
    "routes": {"type": "array", "items": {"$ref": "#/$defs/route"}},
    "entrapmentTargets": {"type": "array", "items": {"$ref": "#/$defs/entrapment"}},
    "topology": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/topology"}]},
    "findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}}
  },
  "$defs": {
    "count": {"type": "integer", "minimum": 0},
    "hash64": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "position": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "prefixItems": [{"type": "integer"}, {"type": "integer"}, {"type": "integer"}],
      "items": false
    },
    "mode": {"enum": ["strict", "optimistic", "executable"]},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mapSha256", "worldIndexSha256"],
      "properties": {
        "mapSha256": {"$ref": "#/$defs/hash64"},
        "worldIndexSha256": {"$ref": "#/$defs/hash64"}
      }
    },
    "region": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "allowDiagonal"],
      "properties": {
        "from": {"$ref": "#/$defs/position"},
        "to": {"$ref": "#/$defs/position"},
        "allowDiagonal": {"type": "boolean"}
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "kind", "transitionId"],
      "properties": {
        "from": {"$ref": "#/$defs/position"},
        "to": {"$ref": "#/$defs/position"},
        "kind": {"enum": ["movement", "transition"]},
        "transitionId": {"type": ["string", "null"]}
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "reason", "mode", "start", "goal", "reachable", "distance", "strictReachable", "optimisticReachable", "conditionalOnly", "baselinePath", "baselineEdges", "criticalEdges", "alternativeEdgeDisjointPath", "alternativeEdgeDisjointEdges", "classification"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "mode": {"$ref": "#/$defs/mode"},
        "start": {"$ref": "#/$defs/position"},
        "goal": {"$ref": "#/$defs/position"},
        "reachable": {"type": "boolean"},
        "distance": {"type": ["integer", "null"], "minimum": 0},
        "strictReachable": {"type": "boolean"},
        "optimisticReachable": {"type": "boolean"},
        "conditionalOnly": {"type": "boolean"},
        "baselinePath": {"type": "array", "items": {"$ref": "#/$defs/position"}},
        "baselineEdges": {"type": "array", "items": {"$ref": "#/$defs/edge"}},
        "criticalEdges": {"type": "array", "items": {"$ref": "#/$defs/edge"}},
        "alternativeEdgeDisjointPath": {"type": "array", "items": {"$ref": "#/$defs/position"}},
        "alternativeEdgeDisjointEdges": {"type": "array", "items": {"$ref": "#/$defs/edge"}},
        "classification": {"enum": ["unreachable", "single-edge-fragile", "edge-disjoint-alternative", "single-edge-resilient-no-full-disjoint-alternative"]}
      }
    },
    "entrapment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "reason", "mode", "entry", "selectedExits", "reachableExits", "nearestReachableExit", "escapePath", "escapeEdges", "classification", "runtimeEntrapmentProven"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "mode": {"$ref": "#/$defs/mode"},
        "entry": {"$ref": "#/$defs/position"},
        "selectedExits": {"type": "array", "items": {"$ref": "#/$defs/position"}},
        "reachableExits": {"type": "array", "items": {"$ref": "#/$defs/position"}},
        "nearestReachableExit": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/position"}]},
        "escapePath": {"type": "array", "items": {"$ref": "#/$defs/position"}},
        "escapeEdges": {"type": "array", "items": {"$ref": "#/$defs/edge"}},
        "classification": {"enum": ["exit-proven", "static-entrapment-candidate"]},
        "runtimeEntrapmentProven": {"const": false}
      }
    },
    "topology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "kinds", "directedTransitionEdgeCount", "oneWayEdges", "deadEnds", "cycles"],
      "properties": {
        "mode": {"$ref": "#/$defs/mode"},
        "kinds": {"type": "array", "items": {"type": "string"}},
        "directedTransitionEdgeCount": {"$ref": "#/$defs/count"},
        "oneWayEdges": {"type": "array", "items": {"type": "object"}},
        "deadEnds": {"type": "array", "items": {"type": "object"}},
        "cycles": {"type": "array", "items": {"type": "object"}}
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "targetId", "classification", "criticalEdges"],
      "properties": {
        "code": {"enum": ["ROUTE_SINGLE_EDGE_FRAGILE", "REVIEWED_ROUTE_UNREACHABLE", "ROUTE_REQUIRES_CONDITIONAL_EVIDENCE", "STATIC_ENTRAPMENT_CANDIDATE", "TRANSITION_ONE_WAY_REVIEW_CANDIDATE", "TRANSITION_DEAD_END_REVIEW_CANDIDATE", "TRANSITION_CLOSED_CYCLE_REVIEW_CANDIDATE"]},
        "targetId": {"type": "string", "minLength": 1},
        "classification": {"type": "string", "minLength": 1},
        "criticalEdges": {"type": "array", "items": {"$ref": "#/$defs/edge"}}
      }
    }
  }
}
