{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://canary.example/schemas/TIBIA_CLIENT_REFERENCE_MANIFEST.schema.json",
  "title": "Canary Tibia Client Reference Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schemaVersion",
    "referenceId",
    "packageRootLabel",
    "sourceRole",
    "observedAt",
    "clientBuild",
    "parserRevision",
    "selectedInputs",
    "generatedIndexes",
    "packageMetadata",
    "summary",
    "policy"
  ],
  "properties": {
    "format": {"const": "canary-tibia-client-reference-manifest-v1"},
    "schemaVersion": {"const": 1},
    "referenceId": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "packageRootLabel": {"type": "string", "minLength": 1},
    "sourceRole": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "observedAt": {"type": "string", "format": "date-time"},
    "clientBuild": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence", "value", "conflictingValues"],
      "properties": {
        "evidence": {"enum": ["proven", "declared", "unknown", "conflicting"]},
        "value": {"type": ["string", "null"]},
        "conflictingValues": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "parserRevision": {"type": "string", "pattern": "^(?:[0-9A-Fa-f]{40}|[0-9A-Fa-f]{64})$"},
    "selectedInputs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "sizeBytes", "sha256"],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
          "path": {"type": "string", "minLength": 1},
          "sizeBytes": {"type": "integer", "minimum": 0},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "generatedIndexes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "sha256"],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "packageMetadata": {
      "type": "object",
      "additionalProperties": {"type": "string", "minLength": 1}
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selectedInputCount", "selectedInputBytes", "generatedIndexCount"],
      "properties": {
        "selectedInputCount": {"type": "integer", "minimum": 1, "maximum": 128},
        "selectedInputBytes": {"type": "integer", "minimum": 0},
        "generatedIndexCount": {"type": "integer", "minimum": 0}
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "explicitSelectionOnly",
        "recursiveDiscovery",
        "executesSelectedContent",
        "packageRootTrustedAsVersionProof",
        "maxSelectedFileBytes"
      ],
      "properties": {
        "explicitSelectionOnly": {"const": true},
        "recursiveDiscovery": {"const": false},
        "executesSelectedContent": {"const": false},
        "packageRootTrustedAsVersionProof": {"const": false},
        "maxSelectedFileBytes": {"type": "integer", "minimum": 1}
      }
    }
  }
}
