{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blakinio/canary/docs/ai-agent/OTBM_REPAIR_RECOMMENDATION_REQUEST.schema.json",
  "title": "Canary OTBM Repair Recommendation Request v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schemaVersion",
    "finding",
    "sourceMapSha256",
    "selector",
    "mutation",
    "runtimeHandlingRequired",
    "rationale"
  ],
  "properties": {
    "format": {"const": "canary-otbm-repair-recommendation-request-v1"},
    "schemaVersion": {"const": 1},
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reportFormat", "reportSha256", "id"],
      "properties": {
        "reportFormat": {"type": "string", "minLength": 1},
        "reportSha256": {"$ref": "#/$defs/sha256"},
        "id": {"type": "string", "minLength": 1}
      }
    },
    "sourceMapSha256": {"$ref": "#/$defs/sha256"},
    "selector": {"$ref": "#/$defs/selector"},
    "mutation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "expectedOldState", "proposedTargetState"],
      "properties": {
        "kind": {
          "enum": [
            "none",
            "attribute-replacement",
            "tile-area-materialization",
            "raw-tile-replacement",
            "raw-tile-insertion",
            "raw-tile-deletion",
            "raw-tile-type-conversion",
            "unsupported"
          ]
        },
        "operationKind": {"type": "string", "minLength": 1},
        "expectedOldState": {},
        "proposedTargetState": {},
        "position": {"$ref": "#/$defs/position"},
        "region": {
          "type": "object",
          "additionalProperties": false,
          "required": ["policy", "from", "to", "translationDelta"],
          "properties": {
            "policy": {"type": "string", "minLength": 1},
            "from": {"$ref": "#/$defs/position"},
            "to": {"$ref": "#/$defs/position"},
            "translationDelta": {"$ref": "#/$defs/position"}
          }
        }
      }
    },
    "runtimeHandlingRequired": {"type": "boolean"},
    "rationale": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "position": {
      "type": "array",
      "prefixItems": [
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"type": "integer", "minimum": 0, "maximum": 15}
      ],
      "minItems": 3,
      "maxItems": 3
    },
    "selector": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "position": {"$ref": "#/$defs/position"},
        "itemId": {"type": "integer", "minimum": 0, "maximum": 65535},
        "actionId": {"type": "integer", "minimum": 0, "maximum": 65535},
        "uniqueId": {"type": "integer", "minimum": 0, "maximum": 65535},
        "houseDoorId": {"type": "integer", "minimum": 0, "maximum": 255},
        "teleportDestination": {"$ref": "#/$defs/position"}
      }
    }
  }
}
