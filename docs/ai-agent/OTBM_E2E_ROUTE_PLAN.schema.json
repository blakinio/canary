{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blakinio/canary/blob/main/docs/ai-agent/OTBM_E2E_ROUTE_PLAN.schema.json",
  "title": "Canary OTBM E2E executable route plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schemaVersion",
    "provenance",
    "inputHashSha256",
    "planHashSha256",
    "origin",
    "destination",
    "routingBounds",
    "routingOptions",
    "routeStatus",
    "executionStatus",
    "routingMode",
    "distance",
    "strictDistance",
    "optimisticDistance",
    "pathComplete",
    "path",
    "edges",
    "blockers"
  ],
  "properties": {
    "format": {"const": "canary-otbm-e2e-route-plan-v1"},
    "schemaVersion": {"const": 1},
    "provenance": {"$ref": "#/$defs/provenance"},
    "inputHashSha256": {"$ref": "#/$defs/sha256"},
    "planHashSha256": {"$ref": "#/$defs/sha256"},
    "origin": {"$ref": "#/$defs/position"},
    "destination": {"$ref": "#/$defs/position"},
    "routingBounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": {"$ref": "#/$defs/position"},
        "to": {"$ref": "#/$defs/position"}
      }
    },
    "routingOptions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowDiagonal", "diagonalCornerCutting", "maxExecutablePositions"],
      "properties": {
        "allowDiagonal": {"type": "boolean"},
        "diagonalCornerCutting": {"const": false},
        "maxExecutablePositions": {"type": "integer", "minimum": 1, "maximum": 10000}
      }
    },
    "routeStatus": {"enum": ["confirmed", "conditional", "unreachable", "invalid"]},
    "executionStatus": {"enum": ["executable", "blocked", "not-applicable"]},
    "routingMode": {
      "oneOf": [
        {"enum": ["strict", "optimistic"]},
        {"type": "null"}
      ]
    },
    "distance": {"$ref": "#/$defs/nullableDistance"},
    "strictDistance": {"$ref": "#/$defs/nullableDistance"},
    "optimisticDistance": {"$ref": "#/$defs/nullableDistance"},
    "pathComplete": {"type": "boolean"},
    "path": {
      "type": "array",
      "maxItems": 10000,
      "items": {"$ref": "#/$defs/position"}
    },
    "edges": {
      "type": "array",
      "maxItems": 9999,
      "items": {"$ref": "#/$defs/edge"}
    },
    "blockers": {
      "type": "array",
      "items": {"$ref": "#/$defs/blocker"}
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"executionStatus": {"const": "executable"}},
        "required": ["executionStatus"]
      },
      "then": {
        "properties": {
          "routeStatus": {"const": "confirmed"},
          "pathComplete": {"const": true},
          "blockers": {"maxItems": 0},
          "provenance": {
            "properties": {
              "map": {"$ref": "#/$defs/hashedEvidence"},
              "worldIndex": {"$ref": "#/$defs/hashedEvidence"},
              "appearances": {"$ref": "#/$defs/hashedEvidence"}
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "position": {
      "type": "array",
      "prefixItems": [
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"type": "integer", "minimum": 0, "maximum": 15}
      ],
      "minItems": 3,
      "maxItems": 3
    },
    "nullableDistance": {
      "oneOf": [
        {"type": "integer", "minimum": 0},
        {"type": "null"}
      ]
    },
    "hashedEvidence": {
      "type": "object",
      "required": ["sha256"],
      "properties": {
        "sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": true
    },
    "nullableHashedEvidence": {
      "oneOf": [
        {"$ref": "#/$defs/hashedEvidence"},
        {"type": "null"}
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["map", "worldIndex", "appearances", "transitionManifest", "scriptResolution"],
      "properties": {
        "map": {"$ref": "#/$defs/nullableHashedEvidence"},
        "worldIndex": {"$ref": "#/$defs/nullableHashedEvidence"},
        "appearances": {"$ref": "#/$defs/nullableHashedEvidence"},
        "transitionManifest": {"$ref": "#/$defs/nullableHashedEvidence"},
        "scriptResolution": {"$ref": "#/$defs/nullableHashedEvidence"}
      }
    },
    "movementEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "edgeSource", "routingMode"],
      "properties": {
        "source": {"const": "reachability-bfs-predecessor"},
        "edgeSource": {"const": "_movement_neighbors"},
        "routingMode": {"enum": ["strict", "optimistic"]}
      }
    },
    "transitionEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "provenanceKey", "transition"],
      "properties": {
        "source": {"const": "validated-transition-edge"},
        "provenanceKey": {"enum": ["worldIndex", "transitionManifest"]},
        "transition": {
          "oneOf": [
            {"type": "object", "additionalProperties": true},
            {"type": "null"}
          ]
        }
      }
    },
    "edge": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["from", "to", "kind", "isTransition", "transitionId", "evidence"],
          "properties": {
            "from": {"$ref": "#/$defs/position"},
            "to": {"$ref": "#/$defs/position"},
            "kind": {"const": "movement"},
            "isTransition": {"const": false},
            "transitionId": {"type": "null"},
            "evidence": {"$ref": "#/$defs/movementEvidence"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["from", "to", "kind", "isTransition", "transitionId", "evidence"],
          "properties": {
            "from": {"$ref": "#/$defs/position"},
            "to": {"$ref": "#/$defs/position"},
            "kind": {"const": "transition"},
            "isTransition": {"const": true},
            "transitionId": {"type": "string", "minLength": 1, "maxLength": 160},
            "evidence": {"$ref": "#/$defs/transitionEvidence"}
          }
        }
      ]
    },
    "blocker": {
      "type": "object",
      "required": ["code"],
      "properties": {
        "code": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    }
  }
}
