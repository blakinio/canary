{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "canary-otbm-tile-area-spans-v1",
  "title": "Canary OTBM tile-area physical spans v1",
  "type": "object",
  "required": ["format", "schemaVersion", "source", "scanner", "mapData", "areas"],
  "properties": {
    "format": {"const": "canary-otbm-tile-area-spans-v1"},
    "schemaVersion": {"const": 1},
    "source": {
      "type": "object",
      "required": ["path", "size", "sha256", "otbmVersion", "width", "height", "itemsMajor", "itemsMinor", "unknownAttributeTails"],
      "properties": {
        "path": {"type": "string"},
        "size": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "otbmVersion": {"type": "integer"},
        "width": {"type": "integer"},
        "height": {"type": "integer"},
        "itemsMajor": {"type": "integer"},
        "itemsMinor": {"type": "integer"},
        "unknownAttributeTails": {"const": 0}
      },
      "additionalProperties": false
    },
    "scanner": {
      "type": "object",
      "required": ["path", "sha256", "nativeFormat"],
      "properties": {
        "path": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "nativeFormat": {"const": "canary-otbm-native-tile-area-spans-v1"}
      },
      "additionalProperties": false
    },
    "mapData": {
      "type": "object",
      "required": ["startOffset", "endOffset", "insertionOffset", "tileAreaSectionContiguous"],
      "properties": {
        "startOffset": {"type": "integer", "minimum": 0},
        "endOffset": {"type": "integer", "minimum": 1},
        "insertionOffset": {"type": "integer", "minimum": 1},
        "tileAreaSectionContiguous": {"const": true}
      },
      "additionalProperties": false
    },
    "areas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["baseX", "baseY", "z", "startOffset", "endOffsetExclusive", "byteLength", "sha256"],
        "properties": {
          "baseX": {"type": "integer", "minimum": 0, "maximum": 65535},
          "baseY": {"type": "integer", "minimum": 0, "maximum": 65535},
          "z": {"type": "integer", "minimum": 0, "maximum": 15},
          "startOffset": {"type": "integer", "minimum": 0},
          "endOffsetExclusive": {"type": "integer", "minimum": 1},
          "byteLength": {"type": "integer", "minimum": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
