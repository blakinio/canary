{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://canary.example/schemas/OTBM_EVIDENCE_GATEWAY_MANIFEST.schema.json",
  "title": "Canary OTBM Evidence Gateway Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "sources"],
  "properties": {
    "format": {"const": "canary-otbm-evidence-gateway-manifest-v1"},
    "schemaVersion": {"const": 1},
    "sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "sha256", "format", "extracts"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9A-Fa-f]{64}$"},
          "format": {"type": "string", "minLength": 1},
          "extracts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "pointer"],
              "properties": {
                "id": {"type": "string", "minLength": 1},
                "pointer": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}
