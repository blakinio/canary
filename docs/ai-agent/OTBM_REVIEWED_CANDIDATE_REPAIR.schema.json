{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blakinio/canary/docs/ai-agent/OTBM_REVIEWED_CANDIDATE_REPAIR.schema.json",
  "title": "Canary OTBM Reviewed Candidate Repair v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schemaVersion",
    "ok",
    "status",
    "source",
    "candidate",
    "recommendation",
    "approval",
    "pipeline",
    "semanticDiff",
    "selection",
    "physicalValidation",
    "provenance",
    "blockers",
    "safety",
    "notes"
  ],
  "properties": {
    "format": {"const": "canary-otbm-reviewed-candidate-repair-v1"},
    "schemaVersion": {"const": 1},
    "ok": {"type": "boolean"},
    "status": {
      "enum": [
        "physically-validated",
        "validated-no-physical-e2e-required",
        "physical-e2e-required"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mapSha256", "unchanged"],
      "properties": {
        "mapSha256": {"$ref": "#/$defs/sha256"},
        "unchanged": {"const": true}
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mapSha256", "createNew", "qualitySourceSha256"],
      "properties": {
        "mapSha256": {"$ref": "#/$defs/sha256"},
        "createNew": {"const": true},
        "qualitySourceSha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "capability", "selector", "mutation"],
      "properties": {
        "state": {
          "enum": [
            "supported-by-existing-attribute-path",
            "supported-by-existing-tile-area-path",
            "supported-by-existing-raw-tile-path"
          ]
        },
        "capability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["family", "mode", "technicalPathSupported", "capabilityOnly"],
          "properties": {
            "family": {"type": "string", "minLength": 1},
            "mode": {"type": "string", "minLength": 1},
            "technicalPathSupported": {"const": true},
            "capabilityOnly": {"const": true}
          }
        },
        "selector": {"$ref": "#/$defs/selector"},
        "mutation": {"type": "object"}
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pipelineMode", "mutationAuthorization", "review"],
      "properties": {
        "pipelineMode": {"$ref": "#/$defs/pipelineMode"},
        "mutationAuthorization": {"$ref": "#/$defs/mutationAuthorization"},
        "review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reviewer", "rationale"],
          "properties": {
            "reviewer": {"type": "string", "minLength": 1},
            "rationale": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "ok"],
      "properties": {
        "mode": {"$ref": "#/$defs/pipelineMode"},
        "ok": {"const": true}
      }
    },
    "semanticDiff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "beforeWorldIndexSha256",
        "afterWorldIndexSha256",
        "scopeType",
        "findingsTotal",
        "findingsTruncated"
      ],
      "properties": {
        "beforeWorldIndexSha256": {"$ref": "#/$defs/sha256"},
        "afterWorldIndexSha256": {"$ref": "#/$defs/sha256"},
        "scopeType": {"enum": ["full-index", "bounded-region"]},
        "findingsTotal": {"type": "integer", "minimum": 0},
        "findingsTruncated": {"type": "boolean"}
      }
    },
    "selection": {"$ref": "#/$defs/selectionCounts"},
    "physicalValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "required", "performed"],
      "properties": {
        "mode": {"enum": ["validate-only", "execute"]},
        "required": {"type": "boolean"},
        "performed": {"type": "boolean"}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recommendation",
        "approval",
        "pipelineResult",
        "semanticDiff",
        "impactedSelection",
        "physicalValidation"
      ],
      "properties": {
        "recommendation": {"$ref": "#/$defs/recommendationPin"},
        "approval": {"$ref": "#/$defs/approvalPin"},
        "pipelineResult": {"$ref": "#/$defs/pipelinePin"},
        "semanticDiff": {"$ref": "#/$defs/semanticDiffPin"},
        "impactedSelection": {"$ref": "#/$defs/selectionPin"},
        "physicalValidation": {"$ref": "#/$defs/physicalPin"}
      }
    },
    "blockers": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approvalGenerated",
        "mapModified",
        "pipelineExecutedByOrchestrator",
        "semanticDiffRecomputed",
        "impactedSelectionRecomputed",
        "physicalE2eExecutedByOrchestrator",
        "existingMutationBoundaryReused",
        "existingCandidateValidationReused",
        "productionMapDeployed",
        "globalGameplayCorrectnessProven"
      ],
      "properties": {
        "approvalGenerated": {"const": false},
        "mapModified": {"const": false},
        "pipelineExecutedByOrchestrator": {"const": false},
        "semanticDiffRecomputed": {"const": false},
        "impactedSelectionRecomputed": {"const": false},
        "physicalE2eExecutedByOrchestrator": {"const": false},
        "existingMutationBoundaryReused": {"const": true},
        "existingCandidateValidationReused": {"const": true},
        "productionMapDeployed": {"const": false},
        "globalGameplayCorrectnessProven": {"const": false}
      }
    },
    "notes": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "physical-e2e-required"}}},
      "then": {
        "properties": {
          "ok": {"const": false},
          "blockers": {"contains": {"const": "SELECTED_PHYSICAL_E2E_NOT_EXECUTED"}}
        }
      },
      "else": {
        "properties": {
          "ok": {"const": true},
          "blockers": {"maxItems": 0}
        }
      }
    }
  ],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "position": {
      "type": "array",
      "prefixItems": [
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"type": "integer", "minimum": 0, "maximum": 15}
      ],
      "minItems": 3,
      "maxItems": 3
    },
    "selector": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "position": {"$ref": "#/$defs/position"},
        "itemId": {"type": "integer", "minimum": 0, "maximum": 65535},
        "actionId": {"type": "integer", "minimum": 0, "maximum": 65535},
        "uniqueId": {"type": "integer", "minimum": 0, "maximum": 65535},
        "houseDoorId": {"type": "integer", "minimum": 0, "maximum": 255},
        "teleportDestination": {"$ref": "#/$defs/position"}
      }
    },
    "pipelineMode": {
      "enum": [
        "fixed-width-attribute",
        "tile-area",
        "tile-replacement",
        "tile-insertion",
        "tile-deletion",
        "tile-type-conversion"
      ]
    },
    "mutationAuthorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "sha256"],
      "properties": {
        "format": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "selectionCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenarioCount", "selectedCount", "skippedCount", "failClosedCount"],
      "properties": {
        "scenarioCount": {"type": "integer", "minimum": 1},
        "selectedCount": {"type": "integer", "minimum": 0},
        "skippedCount": {"type": "integer", "minimum": 0},
        "failClosedCount": {"type": "integer", "minimum": 0}
      }
    },
    "inputPin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fileName", "size", "sha256", "format"],
      "properties": {
        "fileName": {"type": "string", "minLength": 1},
        "size": {"type": "integer", "minimum": 0},
        "sha256": {"$ref": "#/$defs/sha256"},
        "format": {"type": "string", "minLength": 1}
      }
    },
    "recommendationPin": {
      "allOf": [
        {"$ref": "#/$defs/inputPin"},
        {"properties": {"format": {"const": "canary-otbm-repair-recommendation-v1"}}}
      ]
    },
    "approvalPin": {
      "allOf": [
        {"$ref": "#/$defs/inputPin"},
        {"properties": {"format": {"const": "canary-otbm-reviewed-candidate-repair-approval-v1"}}}
      ]
    },
    "pipelinePin": {
      "allOf": [
        {"$ref": "#/$defs/inputPin"},
        {"properties": {"format": {"const": "canary-otbm-repair-materialization-pipeline-v1"}}}
      ]
    },
    "semanticDiffPin": {
      "allOf": [
        {"$ref": "#/$defs/inputPin"},
        {"properties": {"format": {"const": "canary-otbm-semantic-diff-v1"}}}
      ]
    },
    "selectionPin": {
      "allOf": [
        {"$ref": "#/$defs/inputPin"},
        {"properties": {"format": {"const": "canary-otbm-e2e-impacted-selection-v1"}}}
      ]
    },
    "physicalPin": {
      "allOf": [
        {"$ref": "#/$defs/inputPin"},
        {"properties": {"format": {"const": "canary-otbm-candidate-physical-validation-v1"}}}
      ]
    }
  }
}
