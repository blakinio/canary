# Example environment file for the Gameplay Analytics maintenance systemd
# service (tools/analytics/maintain_gameplay_analytics.sh).
#
# Copy this file to /etc/canary/gameplay-analytics-maintenance.env, restrict
# its permissions (chmod 600), and fill in real values there. Never commit a
# filled-in copy of this file to version control.

# Database connection. Use an account restricted to the Analytics tables.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=canary
DB_PASSWORD=CHANGE_ME
DB_NAME=canary

# Catch-up and correction bounds. REAGGREGATE_DAYS rebuilds a recent rolling
# window so delayed or corrected raw sessions replace stale daily groups.
AGGREGATION_LAG_DAYS=1
MAX_DAYS_PER_RUN=31
REAGGREGATE_DAYS=7

# Strictly ascending lower-bound transitions used by daily aggregation.
# The default produces 0-49, 50-99, 100-199, 200-299, 300-399, 400-599,
# 600-799, 800-999 and 1000+ brackets.
LEVEL_BRACKETS=50,100,200,300,400,600,800,1000

RAW_RETENTION_DAYS=180

# Raw session deletion stays opt-in. Only set to true after running with the
# default for several days and comparing both daily aggregate tables against
# raw queries for a few dates, vocations and solo/party modes. When deletion is
# enabled, RAW_RETENTION_DAYS must be greater than REAGGREGATE_DAYS plus
# AGGREGATION_LAG_DAYS.
DELETE_RAW_SESSIONS=false
DELETE_BATCH_SIZE=5000
DELETE_MAX_BATCHES=20
