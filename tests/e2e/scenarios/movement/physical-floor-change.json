{
  "schema_version": 1,
  "id": "physical-floor-change",
  "suite": "movement",
  "name": "Physical client bounded floor transition",
  "program_id": "CAN-PROGRAM-E2E-PLATFORM",
  "description": "Drive the controlled real client from the physically proven Knight 1 start to a bounded non-teleport floor-transition probe selected from the exact World Index and client minimap, record the real route endpoint, then require a real floor delta while preserving the canonical logout, persistence, and relog sentinel. Exact final position is pinned only after physical artifact evidence.",
  "client": {
    "repository": "blakinio/otclient",
    "ref": "2a1b93bcdf6d4317ceeb2254b1e89429453a8e7f",
    "automation": "tools/e2e/client/agent_e2e_scenario.lua"
  },
  "server": {
    "database_image": "mariadb:11.4",
    "datapack": "data-otservbr-global",
    "map": "otservbr"
  },
  "fixture": {
    "account": "@test1",
    "password_env": "AGENT_E2E_TEST_PASSWORD",
    "character": "Knight 1",
    "world": "Canary E2E",
    "host": "127.0.0.1",
    "game_port": 7172
  },
  "timing": {
    "global_timeout_seconds": 180,
    "session_hold_ms": 7000,
    "relog_delay_ms": 1500
  },
  "steps": [
    {"id": "online", "action": "observe_online", "expected": true},
    {"id": "route-east", "action": "walk", "direction": "east", "count": 18, "interval_ms": 350},
    {"id": "route-north", "action": "walk", "direction": "north", "count": 1, "interval_ms": 500},
    {"id": "floor-settle", "action": "wait", "ms": 1500},
    {"id": "endpoint-position", "action": "observe_position_changed"},
    {"id": "floor-delta", "action": "observe_floor_delta", "delta": 1},
    {"id": "position-changed", "action": "observe_position_changed"}
  ],
  "assertions": {
    "required_markers": [
      "ping_features_1=disabled",
      "login_1=success",
      "initial_position=32369,32241,7",
      "online_stable_1=confirmed",
      "step_online=success",
      "step_route-east=success",
      "step_route-north=success",
      "step_floor-settle=success",
      "step_endpoint-position=success",
      "step_floor-delta=success",
      "step_floor-delta_detail=1",
      "step_position-changed=success",
      "plan=success",
      "logout_request_1=safe",
      "logout_1=complete",
      "ping_features_2=disabled",
      "login_2=success",
      "online_stable_2=confirmed",
      "logout_request_2=safe",
      "logout_2=complete",
      "e2e=success"
    ],
    "sql": [
      "SELECT lastlogin > 0 FROM players WHERE name = 'Knight 1'",
      "SELECT lastlogout > 0 FROM players WHERE name = 'Knight 1'"
    ]
  },
  "artifacts": [
