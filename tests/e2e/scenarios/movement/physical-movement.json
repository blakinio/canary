{
  "schema_version": 1,
  "id": "physical-movement",
  "suite": "movement",
  "name": "Physical client movement fixture discovery probe",
  "program_id": "CAN-PROGRAM-E2E-PLATFORM",
  "description": "Probe one bounded real-client movement request on the disposable Canary world while preserving the canonical logout, persistence, and relog sentinel. The exact first-session start is pinned from physical login evidence; the route remains fixture-discovery input until a selected physical movement run proves the resulting position.",
  "client": {
    "repository": "blakinio/otclient",
    "ref": "2a1b93bcdf6d4317ceeb2254b1e89429453a8e7f",
    "automation": "tools/e2e/client/agent_e2e_scenario.lua"
  },
  "server": {
    "database_image": "mariadb:11.4",
    "datapack": "data-otservbr-global",
    "map": "otservbr"
  },
  "fixture": {
    "account": "@test1",
    "password_env": "AGENT_E2E_TEST_PASSWORD",
    "character": "Knight 1",
    "world": "Canary E2E",
    "host": "127.0.0.1",
    "game_port": 7172
  },
  "timing": {
    "global_timeout_seconds": 180,
    "session_hold_ms": 7000,
    "relog_delay_ms": 1500
  },
  "steps": [
    {
      "id": "online",
      "action": "observe_online",
      "expected": true
    },
    {
      "id": "east-one",
      "action": "walk",
      "direction": "east",
      "count": 1,
      "interval_ms": 500
    },
    {
      "id": "movement-settle",
      "action": "wait",
      "ms": 1000
    },
    {
      "id": "position-changed",
      "action": "observe_position_changed"
    }
  ],
  "assertions": {
    "required_markers": [
      "ping_features_1=disabled",
      "login_1=success",
      "initial_position=32369,32241,7",
      "online_stable_1=confirmed",
      "step_online=success",
      "step_east-one=success",
      "step_movement-settle=success",
      "step_position-changed=success",
      "plan=success",
      "logout_request_1=safe",
      "logout_1=complete",
      "ping_features_2=disabled",
      "login_2=success",
      "online_stable_2=confirmed",
      "logout_request_2=safe",
      "logout_2=complete",
      "e2e=success"
    ],
    "sql": [
      "SELECT lastlogin > 0 FROM players WHERE name = 'Knight 1'",
      "SELECT lastlogout > 0 FROM players WHERE name = 'Knight 1'"
    ]
  },
  "artifacts": [
    "scenario-manifest.json",
    "scenario-plan.lua",
    "result.json",
    "client-events.tsv",
    "map.sha256",
    "canary.stdout.log",
    "canary.stderr.log",
    "otclient.stdout.log",
    "otclient.stderr.log",
    "otclient.internal.log",
    "database-online.tsv",
    "database-after.tsv",
    "server-login-matches.txt",
    "client.png",
    "session-1.record",
    "session-2.record",
    "runtime-hashes.txt"
  ]
}
