    {
      "id": "promotion-offer",
      "action": "talk_npc",
      "receiver": "Canary",
      "text": "promot"
    },
    {
      "id": "offer-settle",
      "action": "wait",
      "ms": 250
    },
    {
      "id": "accept",
      "action": "talk_npc",
      "receiver": "Canary",
