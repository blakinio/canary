{
  "schema_version": 1,
  "id": "client-disconnect-recovery",
  "suite": "recovery",
  "name": "Controlled client disconnect and recovery",
  "program_id": "CAN-PROGRAM-E2E-PLATFORM",
  "description": "Enter the disposable Canary world with the real controlled OTClient, inject exactly one explicit maintained-client forceLogout disconnect after stable login, classify that disconnect as expected injected failure, recover through a second real-client login, then perform a safe cleanup logout while preserving the existing two-login/two-packet-record evidence contract.",
  "client": {
    "repository": "blakinio/otclient",
    "ref": "2a1b93bcdf6d4317ceeb2254b1e89429453a8e7f",
    "automation": "tools/e2e/client/agent_e2e_fault_recovery.lua"
  },
  "server": {
    "database_image": "mariadb:11.4",
    "datapack": "data-otservbr-global",
    "map": "otservbr"
  },
  "fixture": {
    "account": "@test1",
    "password_env": "AGENT_E2E_TEST_PASSWORD",
    "character": "Knight 1",
    "world": "Canary E2E",
    "host": "127.0.0.1",
    "game_port": 7172
  },
  "timing": {
    "global_timeout_seconds": 180,
    "session_hold_ms": 7000,
    "relog_delay_ms": 1500
  },
  "assertions": {
    "required_markers": [
      "ping_features_1=disabled",
      "login_1=success",
      "online_stable_1=confirmed",
      "recovery_baseline=confirmed",
      "fault_injection=client_force_logout",
      "fault_expected=client_disconnect",
      "fault_observed=client_disconnect",
      "fault_classification=expected_injected_failure",
      "recovery_state=relogin_pending",
      "ping_features_2=disabled",
      "login_2=success",
      "online_stable_2=confirmed",
      "recovery_login=success",
      "recovery_online=confirmed",
      "logout_request_2=safe",
      "logout_2=complete",
      "cleanup=safe_logout_complete",
      "e2e=success"
    ],
    "sql": [
      "SELECT lastlogin > 0 FROM players WHERE name = 'Knight 1'",
      "SELECT lastlogout > 0 FROM players WHERE name = 'Knight 1'"
    ]
  },
  "artifacts": [
    "scenario-manifest.json",
    "result.json",
    "client-events.tsv",
    "canary.stdout.log",
    "canary.stderr.log",
    "otclient.stdout.log",
    "otclient.stderr.log",
    "otclient.internal.log",
    "database-online.tsv",
    "database-after.tsv",
    "sql-assertions.json",
    "database-sql-assertions-passed.txt",
    "server-login-matches.txt",
    "client.png",
    "session-1.record",
    "session-2.record",
    "runtime-hashes.txt"
  ]
}
