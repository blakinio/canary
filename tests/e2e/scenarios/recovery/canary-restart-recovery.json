    "canary-restart-evidence.json",
    "canary-restart-ready",
    "database-restart-pre-balance.txt",
    "database-restart-pre-relogin-online-count.txt",
    "otclient.stdout.log",
    "otclient.stderr.log",
    "otclient.internal.log",
    "database-online.tsv",
    "database-after.tsv",
    "sql-assertions.json",
    "database-sql-assertions-passed.txt",
    "server-login-matches.txt",
