{
  "schema_version": 1,
  "id": "player-trade-persistence",
  "suite": "multiclient",
  "name": "Real two-player trade with persistence",
  "program_id": "CAN-PROGRAM-E2E-PLATFORM",
  "description": "Run two distinct controlled OTClients against one disposable Canary process, prove both actors initially have zero item 3043, create exactly one tracked item 3043 inside Player A's existing starter backpack through the existing god /i talk action, complete the real bilateral player-trade offer handshake with one existing count-1 Player B counteroffer item, transfer the tracked resource to Player B through maintained-OTClient requestTrade/acceptTrade, prove immediate conservation, then safely logout/relog both actors and prove the same persisted tracked-resource ownership state.",
  "client": {
    "repository": "blakinio/otclient",
    "ref": "2a1b93bcdf6d4317ceeb2254b1e89429453a8e7f",
    "automation": "tests/e2e/scenarios/multiclient/player-trade-persistence/primary.lua"
  },
  "server": {
    "database_image": "mariadb:11.4",
    "datapack": "data-otservbr-global",
    "map": "otservbr"
  },
  "fixture": {
    "account": "@test15",
    "password_env": "AGENT_E2E_TEST_PASSWORD",
    "character": "Paladin 15",
    "world": "Canary E2E",
    "host": "127.0.0.1",
    "game_port": 7172
  },
  "multi_client": {
    "schema_version": 1,
    "secondary": {
      "id": "trade-b",
      "account": "@test14",
      "password_env": "AGENT_E2E_TEST_PASSWORD",
      "character": "Paladin 14"
    }
  },
  "timing": {
    "global_timeout_seconds": 180,
    "session_hold_ms": 7000,
    "relog_delay_ms": 1500
  },
  "assertions": {
    "required_markers": [
      "ping_features_1=disabled",
      "login_1=success",
      "online_stable_1=confirmed",
      "trade_backpack_open_1=confirmed",
      "trade_primary_online=confirmed",
      "multi_client_secondary_started=trade-b",
      "trade_primary_peer_visible=Paladin 14",
      "trade_secondary_peer_visible=Paladin 15",
      "trade_mutual_visibility=confirmed",
      "trade_fixture_precondition=empty",
      "trade_fixture_created=item-3043",
      "trade_request=sent",
      "trade_offer_primary=observed",
      "trade_offer_secondary=observed",
      "trade_accept_secondary=sent",
      "trade_accept_primary=sent",
      "trade_close_primary=observed",
      "trade_close_secondary=observed",
      "trade_immediate_primary=0",
      "trade_immediate_secondary=1",
      "trade_immediate_conservation=1",
      "logout_request_1=safe",
      "logout_1=complete",
      "ping_features_2=disabled",
      "login_2=success",
      "online_stable_2=confirmed",
      "trade_backpack_open_2=confirmed",
      "trade_relog_primary=0",
      "trade_relog_secondary=1",
      "trade_relog_conservation=1",
      "multi_client_secondary_release=sent",
      "multi_client_secondary_exit=clean",
      "logout_request_2=safe",
      "logout_2=complete",
      "e2e=success"
    ],
    "persistence": {
      "required": true,
      "checks": [
        {
          "id": "primary-traded-item-3043-absent",
          "type": "player_item_presence",
          "location": "inventory",
          "item_id": 3043,
          "present": false
        }
      ]
    },
    "sql": [
      "SELECT COUNT(*) = 0 FROM player_items AS pi INNER JOIN players AS p ON p.id = pi.player_id WHERE p.name = 'Paladin 15' AND pi.itemtype = 3043",
      "SELECT COUNT(*) = 1 FROM player_items AS pi INNER JOIN players AS p ON p.id = pi.player_id WHERE p.name = 'Paladin 14' AND pi.itemtype = 3043",
      "SELECT COUNT(*) = 1 FROM player_items AS pi INNER JOIN players AS p ON p.id = pi.player_id WHERE p.name IN ('Paladin 15', 'Paladin 14') AND pi.itemtype = 3043",
      "SELECT lastlogin > 0 AND lastlogout > 0 FROM players WHERE name = 'Paladin 15'",
      "SELECT lastlogin > 0 AND lastlogout > 0 FROM players WHERE name = 'Paladin 14'",
      "SELECT COUNT(*) = 0 FROM players_online"
    ]
  },
  "artifacts": [
    "scenario-manifest.json",
    "result.json",
    "client-events.tsv",
    "multi-client-plan.json",
    "multi-client-secondary.env",
    "actors/trade-b/client-events.tsv",
    "actors/trade-b/otclient.stdout.log",
    "actors/trade-b/otclient.stderr.log",
    "actors/trade-b/otclient.internal.log",
    "actors/trade-b/otclient-exit-code.txt",
    "actors/trade-b/session-1.record",
    "actors/trade-b/session-2.record",
    "canary.stdout.log",
    "canary.stderr.log",
    "otclient.stdout.log",
    "otclient.stderr.log",
    "otclient.internal.log",
    "database-online.tsv",
    "database-after.tsv",
    "sql-assertions.json",
    "database-sql-assertions-passed.txt",
    "server-login-matches.txt",
    "client.png",
    "session-1.record",
    "session-2.record",
    "runtime-hashes.txt"
  ]
}
